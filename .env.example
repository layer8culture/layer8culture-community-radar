# Supabase Postgres connection string (leave blank to run with in-memory mock store)
DATABASE_URL=""

# --- AI provider for /api/generate-comment ---
# Priority order: GITHUB_TOKEN → OPENAI_API_KEY → deterministic fallback templates.

# Option A: GitHub Models (recommended — works with your GitHub account; free tier).
# Create a fine-grained PAT with the `models:read` scope at:
#   https://github.com/settings/personal-access-tokens
# Note: this is NOT your Copilot subscription token. GitHub Models is a separate,
# free, OpenAI-compatible inference API; a Copilot subscription is not required.
GITHUB_TOKEN=""
GITHUB_MODELS_MODEL="openai/gpt-4o-mini"

# Option B: OpenAI (used only if GITHUB_TOKEN is not set).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Real-data ingestion (POST /api/refresh) ---

# YouTube Data API v3 key. Get one free at:
#   https://console.cloud.google.com → "Enable APIs & Services" → "YouTube Data API v3"
# Then Credentials → Create credentials → API key.
YOUTUBE_API_KEY=""

# Reddit reads. Two modes — both work from any IP:
#
# (a) RSS fallback (default): no credentials required. Just set a unique
#     User-Agent. Works on Vercel out of the box. Trade-off: no upvote or
#     comment counts, so engagement velocity uses a flat default and the
#     opportunity score leans more on freshness + relevance.
#
# (b) OAuth (full data): set REDDIT_CLIENT_ID + REDDIT_CLIENT_SECRET below.
#     Use this once your Reddit API application at
#     https://www.reddit.com/prefs/apps is approved.
REDDIT_USER_AGENT="community-radar/0.1 (by /u/your_reddit_username)"
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Optional: protect /api/refresh behind a shared secret.
# When set, the route requires `Authorization: Bearer <secret>`.
# Leave blank for local dev.
CRON_SECRET=""
